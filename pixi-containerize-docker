#!/bin/bash
set -e
PIXITAINER_VERSION="0.6.2"

# Wrapper to echo only if not quiet
log() {
    if [ "$QUIET" = false ]; then
        echo "$@"
    fi
}

# --- Default values ---
OUTPUT="pixitainer:latest"
PROJECT_PATH="."
SEAMLESS=false

if [ -f /etc/os-release ]; then
    source /etc/os-release
    if [ -z "$VERSION_ID" ]; then
        BASE_IMAGE="${ID}:latest"
    else
        BASE_IMAGE="${ID}:${VERSION_ID}"
    fi
else
    echo "⚠️  Warning: /etc/os-release not found. Defaulting to ubuntu:24.04 as base image."
    BASE_IMAGE="ubuntu:24.04"
fi

TARGET_PIXI_VERSION=""
LATEST_PIXI=false
KEEP_DEF=false
VERBOSE=false
QUIET=false
DRY_RUN=false
NO_INSTALL=false
NO_CACHE=false
PUSH=false
SQUASH=false
PLATFORM=""
NETWORK=""
USER_OVERRIDE=""
WORKDIR_OVERRIDE=""
SAVE_FILE=""
declare -a ENVS
declare -a EXTRA_FILES
declare -a POST_COMMANDS
declare -a LABELS
declare -a BUILD_ARGS
declare -a SECRETS
declare -a SSH_AGENTS
declare -a EXTRA_TAGS
declare -a CACHE_FROM
declare -a CACHE_TO

# --- Help ---
usage() {
    echo "Usage: pixi containerize-docker [options]"
    echo ""
    echo "Pixi extension to containerize a project with Docker."
    echo "Version: $PIXITAINER_VERSION"
    echo ""

    echo "Core Options:"
    echo "  -o, --output TAG          Docker image tag (default: pixitainer:latest)"
    echo "  -p, --path PATH           Working directory (source project)"
    echo "  -s, --seamless            Enable seamless execution"
    echo ""

    echo "Environment & Image Setup:"
    echo "  -b, --base-image IMAGE    Specify base image (default: auto-detected from host)"
    echo "  -e, --env ENV             Specific environment(s) to install (can be used multiple times)"
    echo "  -n, --no-install          Do not install any environments"
    echo ""

    echo "Pixi Versioning:"
    echo "  -V, --pixi-version VER    Specify pixi version (default: same as host)"
    echo "  -L, --latest              Force the use of the latest pixi version (cannot be used with -V)"
    echo ""

    echo "Advanced Modifications:"
    echo "  -a, --add-file SRC:DEST   Add a file/folder to the image (format: source:destination)"
    echo "  -c, --post-command CMD    Add a RUN command after environment install (can be used multiple times)"
    echo "  -l, --label KEY:VALUE     Add a custom LABEL to the image (can be used multiple times)"
    echo "  -k, --keep-def            Keep the generated Dockerfile (do not delete it)"
    echo ""

    echo "Docker-specific Options:"
    echo "  --no-cache                Build the Docker image without cache"
    echo "  --push                    Push the image to a registry after building"
    echo "  --platform PLATFORM       Target platform(s) for the build (e.g. linux/amd64,linux/arm64)"
    echo "                            Note: multi-platform builds require docker buildx"
    echo "  --squash                  Squash all layers into a single layer (requires experimental daemon)"
    echo "  --network MODE            Set build-time network mode: bridge (default), host, none"
    echo "  --build-arg KEY=VAL       Set a build-time ARG variable (can be used multiple times)"
    echo "  --secret ID:src=FILE      Mount a BuildKit secret during build (never baked into layers)"
    echo "                            Example: --secret id=pixi_token,src=\$HOME/.pixi/token"
    echo "  --ssh AGENT               Forward SSH agent into the build (e.g. --ssh default)"
    echo "                            Requires DOCKER_BUILDKIT=1 and an active ssh-agent"
    echo "  -t, --tag TAG             Add an extra tag to the image (can be used multiple times)"
    echo "  --cache-from IMAGE        Reuse cache from an existing image (e.g. a registry image for CI)"
    echo "                            Example: --cache-from type=registry,ref=ghcr.io/me/img:cache"
    echo "  --cache-to SPEC           Export cache after build (e.g. type=inline or type=registry,...)"
    echo "  --save FILE               Export the built image to a .tar.gz archive (docker save | gzip)"
    echo "                            Useful on HPC clusters without registry access"
    echo "  --user USER               Run the container as USER (adds USER instruction to Dockerfile)"
    echo "  --workdir PATH            Override the default working directory inside the container"
    echo ""

    echo "Output Options:"
    echo "  -d, --dry-run             Output the Dockerfile to stdout without building the image"
    echo ""

    echo "General Options:"
    echo "  -q, --quiet               Quiet mode (suppress all output, return 0 on success, 1 on error)"
    echo "  -v, --verbose             Verbose mode (show full Docker build output)"
    echo "  -h, --help                Show this help message"
}

# --- Pre-parse path to locate manifest ---
for ((i=1; i<=$#; i++)); do
    if [[ "${!i}" == "-p" ]] || [[ "${!i}" == "--path" ]]; then
        next=$((i+1))
        PROJECT_PATH="${!next}"
        break
    fi
done

TOML_WD=$(cd "$PROJECT_PATH" 2>/dev/null && pwd -P || echo "$PROJECT_PATH")
if [ -f "$TOML_WD/pixi.toml" ]; then
    PRE_MANIFEST_SRC="$TOML_WD/pixi.toml"
elif [ -f "$TOML_WD/pyproject.toml" ]; then
    PRE_MANIFEST_SRC="$TOML_WD/pyproject.toml"
else
    PRE_MANIFEST_SRC=""
fi

# --- TOML section parser (usage: _parse_toml_section SECTION FILE) ---
_parse_toml_section() {
    local section="$1"
    local file="$2"
    local esc_section
    esc_section=$(printf '%s' "$section" | sed 's/\./\\./g')
    awk -v sec="$section" -v esc="$esc_section" '
    $0 ~ ("^\\[" esc "\\]") { flag=1; next }
    /^\[/ { flag=0 }
    flag {
        sub(/#.*/, "")
        gsub(/\r$/, "")
        gsub(/^[ \t]+|[ \t]+$/, "")
        if (!length) next

        if (in_array) {
            accumulated = accumulated " " $0
            if ($0 ~ /\]/) {
                in_array = 0
                print current_key "|" accumulated
                accumulated = ""
                current_key = ""
            }
            next
        }

        idx = index($0, "=")
        if (!idx) next

        key = substr($0, 1, idx-1)
        val = substr($0, idx+1)
        gsub(/^[ \t]+|[ \t]+$/, "", key)
        gsub(/^[ \t]+|[ \t]+$/, "", val)

        if (val ~ /^\[/ && val !~ /\]/) {
            in_array = 1
            current_key = key
            accumulated = val
            next
        }

        print key "|" val
    }
    END {
        if (in_array && current_key != "") {
            print current_key "|" accumulated
        }
    }
    ' "$file"
}

# --- Apply a parsed key/val line to the Docker variable set ---
# reset_mode="true" means we are in the subtable pass: arrays are cleared on
# their first encounter so the subtable fully overrides the general table.
_apply_toml_docker() {
    local key="$1"
    local val="$2"
    local reset_mode="${3:-false}"

    local clean_val
    clean_val=$(echo "$val" | tr -d '\r' | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//")

    case "$key" in
        # Shared options
        output)     OUTPUT="$clean_val" ;;
        path)       PROJECT_PATH="$clean_val" ;;
        seamless)
            if [[ "${clean_val,,}" == "true" ]]; then SEAMLESS=true; else SEAMLESS=false; fi ;;
        base-image) BASE_IMAGE="$clean_val" ;;
        no-install)
            if [[ "${clean_val,,}" == "true" ]]; then NO_INSTALL=true; else NO_INSTALL=false; fi ;;
        pixi-version) TARGET_PIXI_VERSION="$clean_val" ;;
        latest)
            if [[ "${clean_val,,}" == "true" ]]; then LATEST_PIXI=true; else LATEST_PIXI=false; fi ;;
        keep-def)
            if [[ "${clean_val,,}" == "true" ]]; then KEEP_DEF=true; else KEEP_DEF=false; fi ;;
        dry-run)
            if [[ "${clean_val,,}" == "true" ]]; then DRY_RUN=true; else DRY_RUN=false; fi ;;
        quiet)
            if [[ "${clean_val,,}" == "true" ]]; then QUIET=true; else QUIET=false; fi ;;
        verbose)
            if [[ "${clean_val,,}" == "true" ]]; then VERBOSE=true; else VERBOSE=false; fi ;;
        # Docker-specific scalars
        no-cache)
            if [[ "${clean_val,,}" == "true" ]]; then NO_CACHE=true; else NO_CACHE=false; fi ;;
        push)
            if [[ "${clean_val,,}" == "true" ]]; then PUSH=true; else PUSH=false; fi ;;
        squash)
            if [[ "${clean_val,,}" == "true" ]]; then SQUASH=true; else SQUASH=false; fi ;;
        platform) PLATFORM="$clean_val" ;;
        network)   NETWORK="$clean_val" ;;
        user)      USER_OVERRIDE="$clean_val" ;;
        workdir)   WORKDIR_OVERRIDE="$clean_val" ;;
        save)      SAVE_FILE="$clean_val" ;;
        # Array options (shared + docker-specific)
        env|add-file|post-command|label|build-arg|secret|ssh|tag|cache-from|cache-to)
            local elements
            elements=$(echo "$val" | grep -o '"[^"]*"')
            local first_elem=true
            while read -r elem; do
                if [ -n "$elem" ]; then
                    local elem_clean="${elem//\"/}"
                    if [ "$reset_mode" = "true" ] && [ "$first_elem" = "true" ]; then
                        case "$key" in
                            env)          ENVS=() ;;
                            add-file)     EXTRA_FILES=() ;;
                            post-command) POST_COMMANDS=() ;;
                            label)        LABELS=() ;;
                            build-arg)    BUILD_ARGS=() ;;
                            secret)       SECRETS=() ;;
                            ssh)          SSH_AGENTS=() ;;
                            tag)          EXTRA_TAGS=() ;;
                            cache-from)   CACHE_FROM=() ;;
                            cache-to)     CACHE_TO=() ;;
                        esac
                        first_elem=false
                    fi
                    case "$key" in
                        env)          ENVS+=("$elem_clean") ;;
                        add-file)     EXTRA_FILES+=("$elem_clean") ;;
                        post-command) POST_COMMANDS+=("$elem_clean") ;;
                        label)        LABELS+=("$elem_clean") ;;
                        build-arg)    BUILD_ARGS+=("$elem_clean") ;;
                        secret)       SECRETS+=("$elem_clean") ;;
                        ssh)          SSH_AGENTS+=("$elem_clean") ;;
                        tag)          EXTRA_TAGS+=("$elem_clean") ;;
                        cache-from)   CACHE_FROM+=("$elem_clean") ;;
                        cache-to)     CACHE_TO+=("$elem_clean") ;;
                    esac
                fi
            done <<< "$elements"
            ;;
    esac
}

# --- Read TOML configuration ---
# Priority: [tool.pixitainer] < [tool.pixitainer.docker] < CLI
if [ -n "$PRE_MANIFEST_SRC" ]; then
    # Pass 1 — general table
    while IFS="|" read -r key val; do
        [ -z "$key" ] && continue
        _apply_toml_docker "$key" "$val" "false"
    done < <(_parse_toml_section "tool.pixitainer" "$PRE_MANIFEST_SRC")

    # Pass 2 — docker-specific table (overrides general)
    while IFS="|" read -r key val; do
        [ -z "$key" ] && continue
        _apply_toml_docker "$key" "$val" "true"
    done < <(_parse_toml_section "tool.pixitainer.docker" "$PRE_MANIFEST_SRC")
fi

# --- Argument parsing ---
while [[ $# -gt 0 ]]; do
    case $1 in
        # Core Options
        -o|--output)
            OUTPUT="$2"
            shift 2
            ;;
        -p|--path)
            PROJECT_PATH="$2"
            shift 2
            ;;
        -s|--seamless)
            SEAMLESS=true
            shift
            ;;

        # Environment & Image Setup
        -b|--base-image)
            BASE_IMAGE="$2"
            shift 2
            ;;
        -e|--env)
            ENVS+=("$2")
            shift 2
            ;;
        -n|--no-install)
            NO_INSTALL=true
            shift
            ;;

        # Pixi Versioning
        -V|--pixi-version)
            TARGET_PIXI_VERSION="$2"
            shift 2
            ;;
        -L|--latest)
            LATEST_PIXI=true
            shift
            ;;

        # Advanced Modifications
        -a|--add-file)
            EXTRA_FILES+=("$2")
            shift 2
            ;;
        -c|--post-command)
            POST_COMMANDS+=("$2")
            shift 2
            ;;
        -l|--label)
            LABELS+=("$2")
            shift 2
            ;;
        -k|--keep-def)
            KEEP_DEF=true
            shift
            ;;
        -d|--dry-run)
            DRY_RUN=true
            shift
            ;;

        # Docker-specific Options
        --no-cache)
            NO_CACHE=true
            shift
            ;;
        --push)
            PUSH=true
            shift
            ;;
        --squash)
            SQUASH=true
            shift
            ;;
        --platform)
            PLATFORM="$2"
            shift 2
            ;;
        --network)
            NETWORK="$2"
            shift 2
            ;;
        --build-arg)
            BUILD_ARGS+=("$2")
            shift 2
            ;;
        --secret)
            SECRETS+=("$2")
            shift 2
            ;;
        --ssh)
            SSH_AGENTS+=("$2")
            shift 2
            ;;
        -t|--tag)
            EXTRA_TAGS+=("$2")
            shift 2
            ;;
        --cache-from)
            CACHE_FROM+=("$2")
            shift 2
            ;;
        --cache-to)
            CACHE_TO+=("$2")
            shift 2
            ;;
        --save)
            SAVE_FILE="$2"
            shift 2
            ;;
        --user)
            USER_OVERRIDE="$2"
            shift 2
            ;;
        --workdir)
            WORKDIR_OVERRIDE="$2"
            shift 2
            ;;

        # General Options
        -q|--quiet)
            QUIET=true
            shift
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Error: Unknown option: $1"
            usage
            exit 1
            ;;
    esac
done

# --- Argument compatibility checks ---
if [ "$LATEST_PIXI" = true ] && [ -n "$TARGET_PIXI_VERSION" ]; then
    echo "Error: --latest and --pixi-version cannot be used together."
    exit 1
fi

if [ -n "$TARGET_PIXI_VERSION" ]; then
    if ! printf '%s\n%s\n' "0.44.0" "$TARGET_PIXI_VERSION" | sort -V -c 2>/dev/null; then
        echo "Error: Specified Pixi version must be 0.44.0 or newer."
        exit 1
    fi
fi

if [ -n "$PLATFORM" ] && ! docker buildx version > /dev/null 2>&1; then
    echo "Error: --platform requires docker buildx, which is not available."
    exit 1
fi

# secrets and SSH require BuildKit
USE_BUILDKIT=false
if [ ${#SECRETS[@]} -gt 0 ] || [ ${#SSH_AGENTS[@]} -gt 0 ] || [ ${#CACHE_FROM[@]} -gt 0 ] || [ ${#CACHE_TO[@]} -gt 0 ]; then
    USE_BUILDKIT=true
    if ! docker buildx version > /dev/null 2>&1; then
        echo "Error: --secret, --ssh, --cache-from, and --cache-to require docker buildx (BuildKit)."
        exit 1
    fi
fi

if [ "$SQUASH" = true ]; then
    # --squash is an experimental feature; warn but don't abort
    if ! docker info 2>/dev/null | grep -q '"Experimental": true\|experimental: true'; then
        echo "⚠️  Warning: --squash requires experimental features enabled in the Docker daemon."
        echo "   Add { \"experimental\": true } to /etc/docker/daemon.json and restart Docker."
    fi
fi

if [ -n "$SAVE_FILE" ] && [ "$PUSH" = true ]; then
    echo "Error: --save and --push cannot be used together."
    exit 1
fi

if [ -n "$PLATFORM" ] && [ ${#EXTRA_TAGS[@]} -gt 0 ] && [ "$PUSH" = false ] && [ -z "$SAVE_FILE" ]; then
    echo "⚠️  Warning: multi-platform builds with --platform only support loading a single image locally."
    echo "   Consider adding --push or --save to export the multi-platform manifest."
fi

# --- Check Docker is available ---
if ! command -v docker &> /dev/null; then
    echo "Error: docker is not installed or not in PATH."
    exit 1
fi

# --- Resolve paths ---
WD=$(cd "$PROJECT_PATH" && pwd -P)

if [ -f "$WD/pixi.toml" ]; then
    MANIFEST_SRC="$WD/pixi.toml"
    MANIFEST_BASENAME="pixi.toml"
    MANIFEST_DEST="/opt/conf/pixi.toml"
elif [ -f "$WD/pyproject.toml" ]; then
    MANIFEST_SRC="$WD/pyproject.toml"
    MANIFEST_BASENAME="pyproject.toml"
    MANIFEST_DEST="/opt/conf/pyproject.toml"
else
    if [ "$QUIET" = false ]; then
        echo "Error: Neither pixi.toml nor pyproject.toml found in $WD"
    fi
    exit 1
fi

PIXI_LOCK="$WD/pixi.lock"

# Build context lives next to the current working directory
TMP_DIR="$(pwd -P)/.tmp_pixitainer_docker"

log "📦 Containerizing project from: $WD"
log "🐳 Docker image tag: $OUTPUT"

# --- Prepare build context ---
# Docker COPY only works within the build context, so we stage all files
# into a temporary directory that becomes the build context.

# Copy manifest and lock file into context
cp "$MANIFEST_SRC" "$TMP_DIR/ctx/$MANIFEST_BASENAME"
if [ -f "$PIXI_LOCK" ]; then
    cp "$PIXI_LOCK" "$TMP_DIR/ctx/pixi.lock"
    HAS_LOCK=true
else
    HAS_LOCK=false
fi

# --- Stage extra files into the build context ---
COPY_EXTRA_LINES=""
if [ ${#EXTRA_FILES[@]} -gt 0 ]; then
    log "ℹ️  Staging extra files:"
    for file_spec in "${EXTRA_FILES[@]}"; do
        if [[ "$file_spec" == *":"* ]]; then
            src="${file_spec%%:*}"
            dest="${file_spec#*:}"
        else
            src="$file_spec"
            dest="/opt/conf/$(basename "$file_spec")"
        fi
        log "      - $src -> $dest"

        # Resolve src relative to WD
        if [[ "$src" != /* ]]; then
            src_abs="$WD/$src"
        else
            src_abs="$src"
        fi

        if [ ! -e "$src_abs" ]; then
            echo "Error: Extra file/directory not found: $src_abs"
            rm -rf "$TMP_DIR"
            exit 1
        fi

        # Flatten into context under a staging subdirectory
        staged_name="extra_$(echo "$src" | tr '/' '_' | tr ' ' '_')"
        cp -r "$src_abs" "$TMP_DIR/ctx/$staged_name"
        COPY_EXTRA_LINES="$COPY_EXTRA_LINES"$'\n'"COPY ctx/$staged_name $dest"
    done
fi

# --- Build install command ---
if [ "$NO_INSTALL" = true ]; then
    INSTALL_CMD="echo 'Skipping environment installation'"
elif [ ${#ENVS[@]} -eq 1 ]; then
    env="${ENVS[0]}"
    log "ℹ️  Adding environment: $env"
    INSTALL_CMD="pixi install -e $env --frozen"
elif [ ${#ENVS[@]} -gt 1 ]; then
    log "ℹ️  Adding environments:"
    ENV_FLAGS=""
    for env in "${ENVS[@]}"; do
        log "      - $env"
        ENV_FLAGS="$ENV_FLAGS -e $env"
    done
    INSTALL_CMD="pixi install --no-progress $ENV_FLAGS --frozen"
else
    INSTALL_CMD="pixi install --no-progress -a --frozen"
fi

# --- Seamless mode ---
if [ "$SEAMLESS" = true ]; then
    log "ℹ️  Seamless mode enabled"
    ENTRYPOINT_LINE='ENTRYPOINT ["pixi", "run", "--as-is", "-m", "'"$MANIFEST_DEST"'"]'
    CMD_LINE='CMD []'
else
    ENTRYPOINT_LINE='ENTRYPOINT ["/bin/bash", "-c", "exec \"$@\"", "--"]'
    CMD_LINE='CMD ["/bin/bash"]'
fi

# --- Pixi version management ---
PIXI_VERSION=$(pixi -V | grep -o " .*$" | tr -d ' ')

if [ -n "$TARGET_PIXI_VERSION" ]; then
    PIXI_INSTALL_VER="$TARGET_PIXI_VERSION"
    PIXI_VERSION="$TARGET_PIXI_VERSION"
elif [ "$LATEST_PIXI" = true ]; then
    PIXI_INSTALL_VER=""  # install.sh will grab latest by default
    PIXI_VERSION=$(curl -s https://api.github.com/repos/prefix-dev/pixi/releases/latest \
        | grep '"tag_name":' | sed -E 's/.*"v?([^"]+)".*/\1/')
else
    PIXI_INSTALL_VER="$PIXI_VERSION"
fi

# Set the version pin env var used by the pixi install.sh script
if [ -n "$PIXI_INSTALL_VER" ]; then
    PIXI_VERSION_ENV="ENV PIXI_VERSION=$PIXI_INSTALL_VER"
else
    PIXI_VERSION_ENV=""
fi

# --- Labels ---
LABEL_LINES="LABEL Created_With=\"Pixitainer (https://github.com/RaphaelRibes/pixitainer)\" \\"$'\n'"      Pixitainer_Version=\"$PIXITAINER_VERSION\" \\"$'\n'"      Pixi_Version=\"$PIXI_VERSION\""

if [ ${#LABELS[@]} -eq 1 ]; then
    label="${LABELS[0]}"
    log "ℹ️  Adding label: $label"
    key="${label%%:*}"
    val="${label#*:}"
    LABEL_LINES="$LABEL_LINES"$'\n'"LABEL $key=\"$val\""
elif [ ${#LABELS[@]} -gt 1 ]; then
    log "ℹ️  Adding labels:"
    for label in "${LABELS[@]}"; do
        log "      - $label"
        key="${label%%:*}"
        val="${label#*:}"
        LABEL_LINES="$LABEL_LINES"$'\n'"LABEL $key=\"$val\""
    done
fi

# --- Post commands ---
POST_RUN_LINES=""
if [ ${#POST_COMMANDS[@]} -gt 0 ]; then
    if [ ${#POST_COMMANDS[@]} -eq 1 ]; then
        log "ℹ️  Adding post-command: ${POST_COMMANDS[0]}"
    else
        log "ℹ️  Adding post-commands:"
        for cmd in "${POST_COMMANDS[@]}"; do
            log "      - $cmd"
        done
    fi
    for cmd in "${POST_COMMANDS[@]}"; do
        POST_RUN_LINES="$POST_RUN_LINES"$'\n'"RUN $cmd"
    done
fi

# --- Build-arg ARG declarations for Dockerfile ---
BUILD_ARG_LINES=""
if [ ${#BUILD_ARGS[@]} -gt 0 ]; then
    if [ ${#BUILD_ARGS[@]} -eq 1 ]; then
        log "ℹ️  Adding build-arg: ${BUILD_ARGS[0]}"
    else
        log "ℹ️  Adding build-args:"
        for ba in "${BUILD_ARGS[@]}"; do log "      - $ba"; done
    fi
    for ba in "${BUILD_ARGS[@]}"; do
        key="${ba%%=*}"
        BUILD_ARG_LINES="$BUILD_ARG_LINES"$'\n'"ARG $key"
    done
fi

# --- User instruction ---
USER_LINE=""
if [ -n "$USER_OVERRIDE" ]; then
    log "ℹ️  Container will run as user: $USER_OVERRIDE"
    USER_LINE="USER $USER_OVERRIDE"
fi

# --- Workdir override ---
EFFECTIVE_WORKDIR="/opt/conf"
if [ -n "$WORKDIR_OVERRIDE" ]; then
    log "ℹ️  Overriding container WORKDIR to: $WORKDIR_OVERRIDE"
    EFFECTIVE_WORKDIR="$WORKDIR_OVERRIDE"
fi
if [ "$HAS_LOCK" = true ]; then
    LOCK_COPY_LINE="COPY ctx/pixi.lock /opt/conf/pixi.lock"
else
    LOCK_COPY_LINE="# (no pixi.lock found)"
fi

# --- Write Dockerfile ---
DOCKERFILE="$TMP_DIR/Dockerfile"

cat <<EOF > "$DOCKERFILE"
# Generated by Pixitainer $PIXITAINER_VERSION
# https://github.com/RaphaelRibes/pixitainer

FROM $BASE_IMAGE
$BUILD_ARG_LINES

$LABEL_LINES

# --- Environment ---
ENV PIXI_HOME=/opt/pixi
ENV PATH="/opt/pixi/bin:\$PATH"
ENV PIXI_PROJECT_MANIFEST=$MANIFEST_DEST
$PIXI_VERSION_ENV

# --- Copy project files ---
COPY ctx/$MANIFEST_BASENAME $MANIFEST_DEST
$LOCK_COPY_LINE
$COPY_EXTRA_LINES

# --- Install system dependencies & Pixi ---
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \\
    && curl -fsSL https://pixi.sh/install.sh | bash \\
    && apt-get remove -y curl \\
    && apt-get autoremove -y \\
    && apt-get clean \\
    && rm -rf /var/lib/apt/lists/*

# --- Install the Pixi environment ---
WORKDIR $EFFECTIVE_WORKDIR
RUN pixi config set --local run-post-link-scripts insecure \\
    && $INSTALL_CMD \\
    && pixi clean cache --yes
$POST_RUN_LINES

# --- Runtime user ---
$USER_LINE

# --- Entrypoint ---
$ENTRYPOINT_LINE
$CMD_LINE
EOF

# --- Dry-run: output Dockerfile and exit ---
if [ "$DRY_RUN" = true ]; then
    cat "$DOCKERFILE"
    rm -rf "$TMP_DIR"
    exit 0
fi

# --- Build Docker image ---
log "🚀 Starting Docker build..."

# Decide whether to use buildx (required for: platform, secrets, ssh, cache-from/to)
NEED_BUILDX=false
[ -n "$PLATFORM" ] && NEED_BUILDX=true
[ "$USE_BUILDKIT" = true ] && NEED_BUILDX=true

if [ "$NEED_BUILDX" = true ]; then
    CMD=(docker buildx build --progress=plain)
    # For local-only (non-push, non-save) single-platform buildx we need --load
    if [ "$PUSH" = false ] && [ -z "$SAVE_FILE" ] && [ -z "$PLATFORM" ]; then
        CMD+=(--load)
    fi
    [ -n "$PLATFORM" ] && CMD+=(--platform "$PLATFORM")
else
    CMD=(docker build)
fi

# Primary tag
CMD+=(-t "$OUTPUT")

# Extra tags
for tag in "${EXTRA_TAGS[@]}"; do
    log "ℹ️  Adding extra tag: $tag"
    CMD+=(-t "$tag")
done

# No-cache
[ "$NO_CACHE" = true ] && CMD+=(--no-cache)

# Squash
[ "$SQUASH" = true ] && CMD+=(--squash)

# Network
if [ -n "$NETWORK" ]; then
    # BuildKit (buildx) only supports --network host and --network none.
    # --network bridge is a classic builder feature and will cause buildx to error.
    if [ "$NEED_BUILDX" = true ] && [ "$NETWORK" = "bridge" ]; then
        echo "Error: --network bridge is not supported by BuildKit (buildx)."
        echo "       Use --network host or --network none, or avoid flags that require buildx"
        echo "       (--platform, --secret, --ssh, --cache-from, --cache-to)."
        rm -rf "$TMP_DIR"
        exit 1
    fi
    log "ℹ️  Build-time network mode: $NETWORK"
    CMD+=(--network "$NETWORK")
fi

# Build args
for ba in "${BUILD_ARGS[@]}"; do
    CMD+=(--build-arg "$ba")
done

# Secrets (BuildKit)
for secret in "${SECRETS[@]}"; do
    log "ℹ️  Mounting secret: $secret"
    CMD+=(--secret "$secret")
done

# SSH agents (BuildKit)
for agent in "${SSH_AGENTS[@]}"; do
    log "ℹ️  Forwarding SSH agent: $agent"
    CMD+=(--ssh "$agent")
done

# Cache-from
for cf in "${CACHE_FROM[@]}"; do
    log "ℹ️  Using cache-from: $cf"
    CMD+=(--cache-from "$cf")
done

# Cache-to
for ct in "${CACHE_TO[@]}"; do
    log "ℹ️  Exporting cache-to: $ct"
    CMD+=(--cache-to "$ct")
done

# Push flag (for buildx multi-platform; for regular builds we push separately below)
[ "$NEED_BUILDX" = true ] && [ "$PUSH" = true ] && CMD+=(--push)

# Build context: TMP_DIR, Dockerfile inside it
CMD+=(-f "$DOCKERFILE" "$TMP_DIR")

if [ "$QUIET" = true ]; then
    if ! "${CMD[@]}" > /dev/null 2>&1; then
        rm -rf "$TMP_DIR"
        exit 1
    fi
elif [ "$VERBOSE" = true ]; then
    "${CMD[@]}"
else
    # Default mode: spinner + step tracking
    # Classic docker build emits: "Step N/M : INSTRUCTION"
    # BuildKit / buildx --progress=plain emits: "#N [STAGE] INSTRUCTION"
    LOG_FILE="$(mktemp)"
    STEP_FILE="$(mktemp)"

    CURRENT_STEP="Setting up build context"
    echo "$CURRENT_STEP" > "$STEP_FILE"

    SPIN='-\|/'
    i=0

    tput civis 2>/dev/null || true
    trap 'tput cnorm 2>/dev/null || true; rm -f "$LOG_FILE" "$STEP_FILE"' EXIT

    set -o pipefail
    set +e

    "${CMD[@]}" 2>&1 | while IFS= read -r line; do
        echo "$line" >> "$LOG_FILE"

        # Classic docker build: "Step N/M : INSTRUCTION ..."
        if [[ "$line" =~ ^Step\ ([0-9]+)/([0-9]+)\ :\ (.+)$ ]]; then
            STEP_N="${BASH_REMATCH[1]}"
            STEP_TOTAL="${BASH_REMATCH[2]}"
            STEP_LABEL="${BASH_REMATCH[3]}"
            printf "\r [✅] %s\033[K\n" "$CURRENT_STEP"
            CURRENT_STEP="[$STEP_N/$STEP_TOTAL] $STEP_LABEL"
            echo "$CURRENT_STEP" > "$STEP_FILE"
            i=0
        # BuildKit / buildx: "#N [stage description] INSTRUCTION ..."
        elif [[ "$line" =~ ^#([0-9]+)\ \[([^]]+)\]\ (.+)$ ]]; then
            STEP_N="${BASH_REMATCH[1]}"
            STEP_STAGE="${BASH_REMATCH[2]}"
            STEP_LABEL="${BASH_REMATCH[3]}"
            printf "\r [✅] %s\033[K\n" "$CURRENT_STEP"
            CURRENT_STEP="[#$STEP_N $STEP_STAGE] $STEP_LABEL"
            echo "$CURRENT_STEP" > "$STEP_FILE"
            i=0
        fi

        printf "\r [${SPIN:i++%4:1}] %s\033[K" "$(cat "$STEP_FILE")"
    done

    EC=$?
    LAST_STEP=$(cat "$STEP_FILE")

    if [ $EC -eq 0 ]; then
        printf "\r [✅] %s\033[K\n" "$LAST_STEP"
    else
        printf "\r [❌] %s\033[K\n" "$LAST_STEP"
        echo ""
        echo "❌ Docker build failed."
        echo ""
        echo "--- LOGS ---"
        cat "$LOG_FILE"
        rm -rf "$TMP_DIR"
        exit $EC
    fi
fi

log "✅ Success! Docker image built: $OUTPUT"

# --- Push (classic docker build only; buildx already pushed via --push flag) ---
if [ "$PUSH" = true ] && [ "$NEED_BUILDX" = false ]; then
    log "📤 Pushing image to registry..."
    if [ "$QUIET" = true ]; then
        docker push "$OUTPUT" > /dev/null 2>&1
    elif [ "$VERBOSE" = true ]; then
        docker push "$OUTPUT"
    else
        docker push "$OUTPUT"
    fi
    log "✅ Image pushed: $OUTPUT"
fi

# --- Save image to archive ---
if [ -n "$SAVE_FILE" ]; then
    log "💾 Saving image to archive: $SAVE_FILE"
    # Collect all tags to include in the archive
    SAVE_TAGS=("$OUTPUT")
    for tag in "${EXTRA_TAGS[@]}"; do SAVE_TAGS+=("$tag"); done

    SAVE_CMD=(docker save "${SAVE_TAGS[@]}")
    if [ "$QUIET" = true ]; then
        "${SAVE_CMD[@]}" | gzip > "$SAVE_FILE" 2>/dev/null
    elif [ "$VERBOSE" = true ]; then
        "${SAVE_CMD[@]}" | gzip > "$SAVE_FILE"
    else
        "${SAVE_CMD[@]}" | gzip > "$SAVE_FILE"
    fi
    log "✅ Image saved to: $SAVE_FILE"
fi

# --- Keep Dockerfile ---
if [ "$KEEP_DEF" = true ]; then
    # Derive a sensible Dockerfile name from the image tag
    SAFE_TAG=$(echo "$OUTPUT" | tr '/:' '_')
    FINAL_DOCKERFILE="$(pwd -P)/Dockerfile.$SAFE_TAG"
    cp "$DOCKERFILE" "$FINAL_DOCKERFILE"
    log "ℹ️  Dockerfile kept at: $FINAL_DOCKERFILE"
fi

# --- Cleanup ---
if [ -d "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
fi