#!/bin/bash
set -e

# Load shared libraries.
# When installed via conda/pixi: CONDA_PREFIX is set → libs live under $CONDA_PREFIX/opt/pixitainer.
# When run directly from the repo during development: resolve relative to the script itself.
if [ -n "$CONDA_PREFIX" ] && [ -d "$CONDA_PREFIX/opt/pixitainer" ]; then
    _PIXITAINER_LIB="$CONDA_PREFIX/opt/pixitainer"
else
    _PIXITAINER_LIB="$(cd "$(dirname "$0")" && pwd -P)/lib"
fi
source "$_PIXITAINER_LIB/common.sh"
source "$_PIXITAINER_LIB/sif.sh"

BOOTSTRAP_SH="$_PIXITAINER_LIB/bootstrap.sh"

# --- Help ---
usage() {
    echo "Usage: pixi containerize-singularity [options]"
    echo ""
    echo "Pixi extension to containerize a project with Singularity."
    echo "Version: $PIXITAINER_VERSION"
    echo ""

    echo "Core Options:"
    echo "  -o, --output OUTPUT       Output image path (default: pixitainer.sif)"
    echo "  -p, --path PATH           Working directory (source project)"
    echo "  -s, --seamless            Enable seamless execution"
    echo ""

    echo "Environment & Image Setup:"
    echo "  -b, --base-image IMAGE    Specify base image (default: ubuntu:24.04)"
    echo "  -e, --env ENV             Specific environment(s) to install (can be used multiple times)"
    echo "  -n, --no-install          Do not install any environments"
    echo ""

    echo "Pixi Versioning:"
    echo "  -V, --pixi-version VER    Specify pixi version (default: same as host)"
    echo "  -L, --latest              Force the use of the latest pixi version (cannot be used with -V)"
    echo ""

    echo "Advanced Modifications:"
    echo "  -a, --add-file SRC:DEST   Add a file to the container (format: source:destination)"
    echo "  -c, --post-command CMD    Add a command to run in %post section (can be used multiple times)"
    echo "  -l, --label KEY:VALUE     Add a custom label to the image (can be used multiple times)"
    echo "  -k, --keep-def            Export the .def file (do not delete temporary files)"
    echo ""

    echo "Output Options:"
    echo "  -d, --dry-run             Output the .def file to stdout without building the image"
    echo ""

    echo "General Options:"
    echo "  -q, --quiet               Quiet mode (suppress all output, return 0 on success, 1 on error)"
    echo "  -v, --verbose             Verbose mode (show full Singularity build output)"
    echo "  -h, --help                Show this help message"
}

sif_main singularity "$@"
